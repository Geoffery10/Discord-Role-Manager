# Required: Discord bot token
TOKEN=your_discord_bot_token

# -------------------------------------------------------------
# Dashboard settings (optional)
# -------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# -------------------------------------------------------------
# Optional: Authentik OIDC for dashboard login
# Set OAUTH2=true to enable. Leave everything else blank to disable.
# -------------------------------------------------------------
OAUTH2=false
AUTHENTIK_CLIENT_ID=your_authentik_client_id
AUTHENTIK_CLIENT_SECRET=your_authentik_client_secret
AUTHENTIK_ISSUER=https://authentik.example.com/application/o/rolm/
AUTHENTIK_REDIRECT_URI=https://rolm.example.com/callback
AUTHENTIK_USER_INFO_ENDPOINT=https://authentik.example.com/application/o/userinfo/
